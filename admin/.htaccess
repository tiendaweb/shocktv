<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /admin/

    # URLs limpias: /admin/dashboard -> /admin/dashboard.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.+)$ $1.php [L,QSA]
</IfModule>

<FilesMatch "\.php$">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</FilesMatch>
