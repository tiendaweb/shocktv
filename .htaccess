<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Permitir archivos reales y directorios
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # URLs limpias para admin: /admin/dashboard -> /admin/dashboard.php
    RewriteRule ^admin/([^/]+)/?$ admin/$1.php [QSA,L]

    # URLs limpias para API: /api/search -> /api/search.php
    RewriteRule ^api/([^/]+)/?$ api/$1.php [QSA,L]

    # Frontend: Redirigir a index.php
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# Permitir todos los archivos PHP
<FilesMatch "\.php$">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</FilesMatch>

# Proteger archivos sensibles
<Files "config/*">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</Files>

<Files "database/*">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</Files>

<Files "init-db.php">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</Files>
