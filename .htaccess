<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # URLs limpias para admin: /admin/dashboard -> /admin/dashboard.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} ^/admin/ [NC]
    RewriteRule ^admin/(.+)$ admin/$1.php [L,QSA]

    # URLs limpias para API: /api/... -> /api/....php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} ^/api/ [NC]
    RewriteRule ^api/(.+)$ api/$1.php [L,QSA]

    # Frontend: Permitir archivos reales
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Frontend: Redirigir a index.php
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# Permitir todos los archivos PHP
<FilesMatch "\.php$">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</FilesMatch>

# Proteger archivos sensibles
<Files "config/*">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</Files>

<Files "database/*">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</Files>

<Files "init-db.php">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</Files>
