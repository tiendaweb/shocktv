<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Permitir archivos reales
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Redirigir a index.php
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# Mejorar seguridad
<FilesMatch "\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

# Permitir acceso a archivos específicos
<FilesMatch "^(index|admin/|api/|public/).*\.php$">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</FilesMatch>

# Proteger archivos sensibles
<Files "config/*">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</Files>

<Files "database/*">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</Files>

<Files "init-db.php">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</Files>
